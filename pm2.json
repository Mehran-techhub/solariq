{
  "apps": [
    {
      "name": "solariq",
      "cwd": "./solariq_backend",
      "script": "../venv/Scripts/python.exe",
      "args": "app.py",
      "env": {
        "FLASK_ENV": "production",
        "PORT": "5000"
      },
      "watch": false,
      "instances": 1,
      "exec_mode": "fork",
      "max_restarts": 10,
      "restart_delay": 3000,
      "max_memory_restart": "500M",
      "error_file": "../logs/solariq-error.log",
      "out_file": "../logs/solariq-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true
    }
  ]
}
